{
    "name":  "a25-electronic-handover",
    "version":  "1.0.0",
    "private":  true,
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "packageManager":  "pnpm@11.11.0",
    "engines":  {
                    "node":  "\u003e=22.14.0"
                },
    "scripts":  {
                    "dev":  "turbo run dev --parallel --filter=@a25/*",
                    "dev:web":  "pnpm --filter @a25/web dev",
                    "dev:api":  "pnpm --filter @a25/api dev",
                    "dev:worker":  "pnpm --filter @a25/worker dev",
                    "build":  "turbo run build --filter=@a25/*",
                    "lint":  "turbo run lint --filter=@a25/*",
                    "typecheck":  "turbo run typecheck --filter=@a25/*",
                    "test":  "turbo run test --filter=@a25/*",
                    "test:e2e":  "pnpm --filter @a25/web test:e2e",
                    "format":  "prettier --write .",
                    "db:generate":  "pnpm --filter @a25/api db:generate",
                    "db:migrate":  "supabase db push",
                    "db:seed":  "pnpm --filter @a25/api db:seed",
                    "supabase:start":  "supabase start",
                    "supabase:stop":  "supabase stop",
                    "supabase:reset":  "supabase db reset"
                },
    "devDependencies":  {
                            "@types/node":  "^22.19.19",
                            "eslint":  "^9.39.4",
                            "prettier":  "^3.6.2",
                            "supabase":  "^2.39.2",
                            "turbo":  "2.5.8",
                            "typescript":  "^5.9.3"
                        }
}
